# First human: org owner of the community. Everything else (members,
# role grants) is self-service via the ZITADEL console afterwards.
resource "random_password" "admin_initial" {
  length           = 24
  special          = true
  min_lower        = 2
  min_upper        = 2
  min_numeric      = 2
  min_special      = 1
  override_special = "!@#$%^&*"
}

resource "zitadel_human_user" "admin" {
  org_id             = module.community.org_id
  user_name          = "admin"
  first_name         = "Admin"
  last_name          = "{{ community_name }}"
  display_name       = "Admin ({{ community_name }})"
  preferred_language = "en"
  email              = "{{ acme_email }}"
  is_email_verified  = true
  initial_password   = random_password.admin_initial.result
}

resource "zitadel_org_member" "admin_owner" {
  org_id  = module.community.org_id
  user_id = zitadel_human_user.admin.id
  roles   = ["ORG_OWNER"]
}

output "admin_initial_password" {
  value       = random_password.admin_initial.result
  description = "Initial password for the admin user — must be changed on first login. Read once with `tofu output -raw admin_initial_password`."
  sensitive   = true
}
