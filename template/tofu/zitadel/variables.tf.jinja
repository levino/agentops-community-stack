variable "zitadel_domain" {
  type        = string
  description = "FQDN of the ZITADEL instance."
  default     = "id.{{ domain }}"
}

variable "jwt_profile_file" {
  type        = string
  description = <<-EOT
    Path to the ZITADEL service-user key JSON used by the provider for the
    one-time bootstrap apply. This is an OPERATOR-HELD credential, provided
    per session and never committed, never stored in the cluster as a standing
    credential (invariants 3 + 6 — see README.md). Prefer minting a scoped
    service-user PAT/key in the console for the session and discarding it
    afterwards.

    Anti-pattern (do not do this on a real instance): parking the chart's
    iam-admin key from the zitadel k8s secret on disk as the permanent
    provider credential. The CI harness does extract it, but CI is a throwaway
    cluster — production identity work is API/console, not standing tofu.

    The file is gitignored and must never be committed.
  EOT
  default     = "./service-user.json"
}
