# OIDC client for the ForwardAuth front door (patterns/app-forwardauth):
# one oauth2-proxy instance protects every app that cannot do its own auth.
resource "zitadel_project" "infrastructure" {
  org_id                   = module.community.org_id
  name                     = "infrastructure"
  project_role_assertion   = true
  project_role_check       = false
  has_project_check        = false
  private_labeling_setting = "PRIVATE_LABELING_SETTING_UNSPECIFIED"
}

resource "zitadel_application_oidc" "forwardauth" {
  org_id     = module.community.org_id
  project_id = zitadel_project.infrastructure.id

  name             = "forwardauth"
  app_type         = "OIDC_APP_TYPE_WEB"
  response_types   = ["OIDC_RESPONSE_TYPE_CODE"]
  grant_types      = ["OIDC_GRANT_TYPE_AUTHORIZATION_CODE", "OIDC_GRANT_TYPE_REFRESH_TOKEN"]
  auth_method_type = "OIDC_AUTH_METHOD_TYPE_BASIC"

  redirect_uris = [
    "https://auth.{{ domain }}/oauth2/callback",
  ]
  post_logout_redirect_uris = [
    "https://auth.{{ domain }}/",
  ]

  access_token_type           = "OIDC_TOKEN_TYPE_BEARER"
  access_token_role_assertion = true
  id_token_role_assertion     = true
  id_token_userinfo_assertion = true

  dev_mode = false
}

output "forwardauth_client_id" {
  value       = zitadel_application_oidc.forwardauth.client_id
  description = "OIDC client ID for oauth2-proxy (patterns/app-forwardauth)."
  sensitive   = true
}

output "forwardauth_client_secret" {
  value       = zitadel_application_oidc.forwardauth.client_secret
  description = "OIDC client secret for oauth2-proxy — goes into the sealed secret, see the pattern's README."
  sensitive   = true
}
