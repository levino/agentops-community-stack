#!/usr/bin/env bash
# Layer-2 generator: stamp out the per-app pattern (namespace, Argo CD
# Application, optional PR-preview ApplicationSet, TLS ingress). See apps/README.md.
#
# Own app (blessed path — the app repo owns deploy/overlays/production):
#   scripts/new-app.sh <name> --repo <github-url> [--path deploy/overlays/production]
#                             [--no-previews] [--preview-path deploy/overlays/preview]
#
# Third-party / in-repo app:
#   scripts/new-app.sh <name> --domain <host> --image <image> [--port 80] [--protected]
set -euo pipefail

cd "$(dirname "$0")/.."

usage() {
  sed -n '2,10p' "scripts/$(basename "$0")"
  exit 1
}

[ $# -ge 1 ] || usage
NAME=$1
shift
[[ "$NAME" =~ ^[a-z0-9][a-z0-9-]*$ ]] || { echo "error: name must be lowercase DNS-safe" >&2; exit 1; }

DOMAIN="" IMAGE="" PORT=80 PROTECTED=0 REPO="" REPO_PATH="deploy/overlays/production"
PREVIEWS=1 PREVIEW_PATH="deploy/overlays/preview"
while [ $# -gt 0 ]; do
  case "$1" in
    --domain) DOMAIN=$2; shift 2 ;;
    --image) IMAGE=$2; shift 2 ;;
    --port) PORT=$2; shift 2 ;;
    --protected) PROTECTED=1; shift ;;
    --repo) REPO=$2; shift 2 ;;
    --path) REPO_PATH=$2; shift 2 ;;
    --no-previews) PREVIEWS=0; shift ;;
    --preview-path) PREVIEW_PATH=$2; shift 2 ;;
    *) echo "error: unknown argument $1" >&2; usage ;;
  esac
done

register() {
  # Add an entry to apps/kustomization.yaml (idempotent).
  local entry=$1
  if grep -qE "^[[:space:]]*-[[:space:]]*${entry}[[:space:]]*$" apps/kustomization.yaml; then
    return
  fi
  if grep -q 'resources: \[\]' apps/kustomization.yaml; then
    sed -i "s|resources: \[\]|resources:\n  - ${entry}|" apps/kustomization.yaml
  else
    printf '  - %s\n' "$entry" >> apps/kustomization.yaml
  fi
}

if [ -n "$REPO" ]; then
  # ---- blessed path: register an app that owns its own deploy/ overlay ----
  REPO_SLUG=${REPO#https://github.com/}
  REPO_SLUG=${REPO_SLUG%.git}
  [[ "$REPO_SLUG" == */* ]] || { echo "error: --repo must be a https://github.com/<owner>/<repo> URL" >&2; exit 1; }
  REPO_OWNER=${REPO_SLUG%%/*}
  REPO_NAME=${REPO_SLUG#*/}

  cat > "apps/${NAME}.yaml" <<EOF
apiVersion: v1
kind: Namespace
metadata:
  name: ${NAME}
---
# Production: Argo CD pulls the app repo's overlay and rolls it forward on
# every push to main — pull-based, so CI never needs cluster access.
# For a PRIVATE app repo, register that org's GitHub App repo credential in
# Argo CD ONCE (runbooks/argocd-github-app.md) — App credentials are
# infrastructure: created in the cluster, NEVER committed, not even sealed
# (AGENTS.md inv. 3).
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: ${NAME}
  namespace: argocd
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: community
  source:
    repoURL: ${REPO}
    targetRevision: main
    path: ${REPO_PATH}
  destination:
    server: https://kubernetes.default.svc
    namespace: ${NAME}
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
EOF
  register "${NAME}.yaml"
  echo "Created apps/${NAME}.yaml (Argo CD pulls ${REPO} → ${REPO_PATH})"

  if [ "$PREVIEWS" = "1" ]; then
    # ApplicationSet with a PullRequest generator: one preview Application per
    # OPEN PR of the app repo, deployed into its own namespace and AUTOMATICALLY
    # PRUNED when the PR closes — Argo's native answer to the disk-pressure
    # incident (runbooks/incidents/disk-pressure.md). The app repo must carry a
    # preview overlay at ${PREVIEW_PATH}. For a private repo (or to avoid
    # GitHub API rate limits), set tokenRef to the org's Argo GitHub App
    # secret — see runbooks/argocd-github-app.md.
    cat > "apps/${NAME}-previews.yaml" <<EOF
{% raw %}apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: ${NAME}-previews
  namespace: argocd
spec:
  goTemplate: true
  goTemplateOptions: ["missingkey=error"]
  generators:
    - pullRequest:
        github:
          owner: ${REPO_OWNER}
          repo: ${REPO_NAME}
          # tokenRef:                       # uncomment for private repos / rate limits
          #   secretName: ${REPO_OWNER}-argocd-secret
          #   key: githubAppPrivateKey
        requeueAfterSeconds: 60
  template:
    metadata:
      name: '${NAME}-pr-{{ .number }}'
    spec:
      project: community
      source:
        repoURL: ${REPO}
        targetRevision: '{{ .head_sha }}'
        path: ${PREVIEW_PATH}
      destination:
        server: https://kubernetes.default.svc
        namespace: '${NAME}-pr-{{ .number }}'
      syncPolicy:
        automated:
          prune: true
          selfHeal: true
        syncOptions:
          - CreateNamespace=true
{% endraw %}EOF
    register "${NAME}-previews.yaml"
    echo "Created apps/${NAME}-previews.yaml (PR previews → ${REPO_PATH%/production}/preview, auto-pruned on close)"
  fi

  echo "Next: commit & push. If the app needs login, see patterns/app-native-oidc/."
  echo "PR previews: see patterns/app-preview-prs/ for the overlay the app repo must carry."
  exit 0
fi

# ---- in-repo path: third-party app, manifests live here ----
[ -n "$DOMAIN" ] && [ -n "$IMAGE" ] || usage

ANNOTATIONS=""
if [ "$PROTECTED" = "1" ]; then
  ANNOTATIONS="
    traefik.ingress.kubernetes.io/router.middlewares: forwardauth-oauth-errors@kubernetescrd,forwardauth-forwardauth@kubernetescrd"
fi

mkdir -p "apps/${NAME}"
cat > "apps/${NAME}/kustomization.yaml" <<EOF
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources:
  - app.yaml
EOF

cat > "apps/${NAME}/app.yaml" <<EOF
apiVersion: v1
kind: Namespace
metadata:
  name: ${NAME}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: ${NAME}
  namespace: ${NAME}
spec:
  replicas: 1
  revisionHistoryLimit: 2
  progressDeadlineSeconds: 300
  selector:
    matchLabels:
      app: ${NAME}
  template:
    metadata:
      labels:
        app: ${NAME}
    spec:
      containers:
        - name: app
          # Must be built for {{ target_arch }} (the server's architecture).
          image: ${IMAGE}
          ports:
            - containerPort: ${PORT}
---
apiVersion: v1
kind: Service
metadata:
  name: ${NAME}
  namespace: ${NAME}
spec:
  selector:
    app: ${NAME}
  ports:
    - port: 80
      targetPort: ${PORT}
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ${NAME}
  namespace: ${NAME}
  annotations:
    cert-manager.io/cluster-issuer: acme${ANNOTATIONS}
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - ${DOMAIN}
      secretName: ${NAME}-tls
  rules:
    - host: ${DOMAIN}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: ${NAME}
                port:
                  number: 80
EOF

register "${NAME}/"
echo "Created apps/${NAME}/ (${IMAGE} at https://${DOMAIN})"
if [ "$PROTECTED" = "1" ]; then
  echo "Protected by ForwardAuth — patterns/app-forwardauth/ must be deployed."
fi
echo "Next: commit & push — Argo CD rolls it out."
