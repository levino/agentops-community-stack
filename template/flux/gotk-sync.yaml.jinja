# GitOps entry point: this repo is the single source of truth.
# Applied once manually during bootstrap (see runbooks/bootstrap-from-zero.md);
# from then on Flux reconciles itself from git.
apiVersion: source.toolkit.fluxcd.io/v1
kind: GitRepository
metadata:
  name: flux-system
  namespace: flux-system
spec:
  interval: 1m0s
  url: https://github.com/{{ github_owner }}/{{ project_name }}
  ref:
    branch: main
  # Private repos: authenticate with the instance's Flux GitHub App — NEVER a
  # PAT (invariant 4). The secret is created directly in the cluster, never
  # committed (invariant 3). One secret per ORG: same private key, that org's
  # installation ID. See runbooks/flux-github-app.md. Uncomment for the org
  # that owns THIS repo ({{ github_owner }}):
  provider: github
  # secretRef:
  #   name: {{ github_owner }}-flux-secret
---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: flux-system
  namespace: flux-system
spec:
  interval: 10m0s
  path: ./flux
  prune: false
  sourceRef:
    kind: GitRepository
    name: flux-system
---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: cluster
  namespace: flux-system
spec:
  interval: 10m0s
  path: ./cluster
  prune: false
  sourceRef:
    kind: GitRepository
    name: flux-system
  dependsOn:
    - name: flux-system
---
# ZITADEL is a separate Kustomization: it depends on sealed secrets that are
# only committed during bootstrap (scripts/seal-zitadel-secrets.sh). Until
# they exist, only this Kustomization fails — the substrate stays healthy.
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: zitadel
  namespace: flux-system
spec:
  interval: 10m0s
  path: ./zitadel
  prune: false
  sourceRef:
    kind: GitRepository
    name: flux-system
  dependsOn:
    - name: cluster
---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: apps
  namespace: flux-system
spec:
  interval: 10m0s
  path: ./apps
  prune: false
  sourceRef:
    kind: GitRepository
    name: flux-system
  dependsOn:
    - name: cluster
